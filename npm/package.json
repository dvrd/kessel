{
  "name": "kessel",
  "version": "0.1.0",
  "description": "Fast JavaScript/TypeScript/JSX/TSX parser. ESTree-compatible ASTs. 8% faster than OXC at the npm boundary.",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./binary-reader": "./binary-reader.js",
    "./visitor": "./visitor.js"
  },
  "files": [
    "index.js",
    "binary-reader.js",
    "visitor.js",
    "bin/",
    "CHANGELOG.md"
  ],
  "scripts": {
    "prepack": "node scripts/prepack.js",
    "test": "node test.js"
  },
  "optionalDependencies": {
    "@kessel/darwin-arm64": "0.1.0",
    "@kessel/darwin-x64": "0.1.0",
    "@kessel/linux-arm64": "0.1.0",
    "@kessel/linux-x64": "0.1.0"
  },
  "dependencies": {
    "koffi": "^3.0.1"
  },
  "engines": { "node": ">=18" },
  "keywords": ["parser", "javascript", "typescript", "jsx", "tsx", "estree", "ast", "fast"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/user/kessel"
  }
}
