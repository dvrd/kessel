// Lifted verbatim from oxc tasks/coverage/src/typescript/constants.rs.
// Sync date: 2026-05-14. OXC SHA f350b523 (matches our pinned vendor
// TYPESCRIPT_SHA and OXC's clone-parallel.mjs).
//
// These two lists exclude TSC-corpus fixtures whose expected behavior
// depends on TSC-the-compiler's type-checker / compiler-options surface
// area rather than parser conformance:
//
//   * NOT_SUPPORTED_TEST_PATHS — file basenames whose expected behavior
//     conflicts with kessel's "always ESNext, always strict" defaults.
//   * NOT_SUPPORTED_ERROR_CODES — TS diagnostic codes that originate from
//     type-checking (not parsing); when a fixture's expected error set
//     consists entirely of these codes we treat it as `should_fail = false`.
//
// Bumping these in lockstep with OXC keeps our typescript snap directly
// comparable to OXC's parser_typescript.snap.
package coverage

@(rodata)
TS_NOT_SUPPORTED_TEST_PATHS := [?]string{
	"functionWithUseStrictAndSimpleParameterList.ts",
	"parameterInitializerBeforeDestructuringEmit.ts",
	"unicodeExtendedEscapesInRegularExpressions01.ts",
	"unicodeExtendedEscapesInRegularExpressions02.ts",
	"unicodeExtendedEscapesInRegularExpressions03.ts",
	"unicodeExtendedEscapesInRegularExpressions04.ts",
