package lexer

// SIMD-accelerated operations for the lexer
// Focuses on whitespace detection and character class matching

import "base:intrinsics"

// Platform detection
when ODIN_ARCH == .arm64 {
	// ARM64 NEON implementation
	IS_ARM64 :: true
	IS_X86 :: false
} else when ODIN_ARCH == .amd64 {
	IS_ARM64 :: false
	IS_X86 :: true
} else {
	IS_ARM64 :: false
	IS_X86 :: false
}

// Whitespace detection using NEON (ARM64)
// Checks 16 bytes at once for whitespace characters
skip_whitespace_neon :: proc(data: []byte) -> (advanced: int, found_newline: bool) {
	when !IS_ARM64 {
		return 0, false
	}
	
	if len(data) < 16 {
		return 0, false
	}
	
	// NEON vectors for whitespace characters
	// Space = 0x20, Tab = 0x09, LF = 0x0A, CR = 0x0D
	
	// This is pseudo-code - actual NEON intrinsics would be:
	// vld1q_u8 to load 16 bytes
	// vceqq_u8 to compare against each whitespace char
	// vorrq_u8 to combine results
	// vaddvq_u8 to reduce and check if any matched
	
	// For now, use the chunked scalar approach
	return skip_whitespace_chunked(data)
}

// Generic chunked whitespace detection
// Process 16 bytes at a time using unrolled scalar code
skip_whitespace_chunked :: proc(data: []byte) -> (advanced: int, found_newline: bool) {
	if len(data) < 16 {
		return 0, false
	}
	
	count := 0
	newline := false
	
	// Unroll loop for better instruction-level parallelism
	for i := 0; i < 16 && i < len(data); i += 1 {
		c := data[i]
		if c == ' ' || c == '\t' || c == '\r' || c == '\n' {
			count += 1
			if c == '\n' {
				newline = true
			}
		} else {
			break
		}
	}
	
	return count, newline
}

// Fast identifier character check
// Returns true if all bytes in chunk are valid identifier characters
is_identifier_chunk :: proc(data: []byte) -> int {
	if len(data) < 8 {
		return 0
	}
	
	count := 0
	for i := 0; i < 8 && i < len(data); i += 1 {
		c := data[i]
		// ASCII identifier rules: a-z, A-Z, 0-9, _, $
		if (c >= 'a' && c <= 'z') || 
		   (c >= 'A' && c <= 'Z') ||
		   (c >= '0' && c <= '9') ||
		   c == '_' || c == '$' {
			count += 1
		} else {
			break
		}
	}
	
	return count
}

// SIMD-optimized string matching for keywords
// Uses 8-byte comparison for common keyword lengths
match_keyword_fast :: proc(data: []byte, keyword: string) -> bool {
	if len(data) < len(keyword) {
		return false
	}
	
	// Fast length check
	if len(keyword) <= 8 {
		// Build 64-bit chunks and compare
		chunk: u64 = 0
		expected: u64 = 0
		
		// Build chunk from data
		#no_bounds_check for i := 0; i < len(keyword); i += 1 {
			chunk |= u64(data[i]) << uint(i * 8)
			expected |= u64(keyword[i]) << uint(i * 8)
		}
		
		return chunk == expected
	}
	
	// Fall back to string comparison for longer keywords
	return string(data[:len(keyword)]) == keyword
}
